{
  "name": "uitodemo",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "author": "Jefferson Lopez",
  "license": "MIT",
  "description": "Timeline-driven UI demo player for product walkthroughs.",
  "keywords": [
    "react",
    "demo",
    "timeline",
    "walkthrough",
    "product-demo",
    "ui"
  ],
  "homepage": "https://github.com/jefferson-lopez/uitodemo-npm#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/jefferson-lopez/uitodemo-npm.git",
    "directory": "packages/uitodemo"
  },
  "bugs": {
    "url": "https://github.com/jefferson-lopez/uitodemo-npm/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/jefferson-lopez"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "default": "./dist/testing.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "pnpm build && node --test test/*.test.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "tsc --project tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "tsup": "^8.4.0"
  },
  "dependencies": {
    "@tabler/icons": "^3.40.0"
  }
}
