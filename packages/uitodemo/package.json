{
  "name": "uitodemo",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "description": "Timeline-driven UI demo player for product walkthroughs.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "default": "./dist/testing.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "pnpm build && node --test test/*.test.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "tsc --project tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "tsup": "^8.4.0"
  },
  "dependencies": {
    "@tabler/icons": "^3.40.0"
  }
}
